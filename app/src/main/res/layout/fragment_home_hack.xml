<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="10.0dip"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:src="@drawable/game_blaster_bomb"
            style="@style/Theme.CheatUIDev.MainActivity.CategoryIcon" />
        <TextView
            android:text="@string/app_name"
            style="@style/Theme.CheatUIDev.MainActivity.CategoryTitle" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="2.0">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/version_installed"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryKeyText" />
                <TextView
                    android:id="@+id/version_label"
					android:text="1.0.1 (697ddd369)"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryValueText" />
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/version_latest"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryKeyText" />
                <TextView
                    android:id="@+id/version_latest"
					android:text="1.0.1"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryValueText" />
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/safety_status"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryKeyText" />
                <TextView
                    android:id="@+id/safe_status"
					android:text="Safe"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryValueText" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/hack_download_button"
                android:visibility="gone"
                android:text="@string/action_update"
                app:icon="@drawable/ic_download"
                style="@style/Theme.CheatUIDev.MainActivity.ActionButton" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
