<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="10.0dip"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:src="@drawable/ic_account"
            style="@style/Theme.CheatUIDev.MainActivity.CategoryIcon" />
        <TextView
            android:text="@string/account"
            style="@style/Theme.CheatUIDev.MainActivity.CategoryTitle" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="2.0">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/nickname"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryKeyText" />
                <TextView
                    android:id="@+id/nickname_text"
					android:text="MrCode403"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryValueText" />
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:text="@string/subscription_expire"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryKeyText" />
                <TextView
                    android:id="@+id/subscription_expire_text"
					android:text="In 69 Hours"
                    style="@style/Theme.CheatUIDev.MainActivity.SummaryValueText" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.google.android.material.button.MaterialButton
                android:textColor="?colorError"
                android:id="@+id/logout_button"
                android:text="@string/action_logout"
                app:icon="@drawable/ic_exit"
                app:iconTint="?colorError"
                style="@style/Theme.CheatUIDev.MainActivity.ActionButton" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
